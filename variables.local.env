SERVICE_PORT=8080
APP_VERSION=local

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pos_transaction
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

EXTERNAL_CLIENT_BASE_URL=http://localhost:8089
EXTERNAL_CLIENT_CONNECT_TIMEOUT_MILLIS=1000
EXTERNAL_CLIENT_READ_TIMEOUT_MILLIS=2000
EXTERNAL_MOCK_SCENARIO_AUTHORIZE=
EXTERNAL_MOCK_SCENARIO_CONFIRM=
EXTERNAL_MOCK_SCENARIO_VOID=

OTLP_METRICS_EXPORT_ENABLED=true
OTLP_METRICS_EXPORT_URL=http://localhost:4318/v1/metrics

OTLP_TRACING_EXPORT_ENABLED=true
OTLP_TRACING_ENDPOINT=http://localhost:4318/v1/traces
TRACING_SAMPLING_PROBABILITY=1.0

EXTERNAL_AUTHORIZE_RETRY_MAX_ATTEMPTS=3
EXTERNAL_AUTHORIZE_RETRY_WAIT_DURATION=300ms
EXTERNAL_AUTHORIZE_RETRY_ENABLE_EXPONENTIAL_BACKOFF=true
EXTERNAL_AUTHORIZE_RETRY_EXPONENTIAL_BACKOFF_MULTIPLIER=2.0
EXTERNAL_AUTHORIZE_RETRY_EXPONENTIAL_MAX_WAIT_DURATION=2s
EXTERNAL_AUTHORIZE_RETRY_ENABLE_RANDOMIZED_WAIT=true
EXTERNAL_AUTHORIZE_RETRY_RANDOMIZED_WAIT_FACTOR=0.5

EXTERNAL_CONFIRM_RETRY_MAX_ATTEMPTS=3
EXTERNAL_CONFIRM_RETRY_WAIT_DURATION=300ms
EXTERNAL_CONFIRM_RETRY_ENABLE_EXPONENTIAL_BACKOFF=true
EXTERNAL_CONFIRM_RETRY_EXPONENTIAL_BACKOFF_MULTIPLIER=2.0
EXTERNAL_CONFIRM_RETRY_EXPONENTIAL_MAX_WAIT_DURATION=2s
EXTERNAL_CONFIRM_RETRY_ENABLE_RANDOMIZED_WAIT=true
EXTERNAL_CONFIRM_RETRY_RANDOMIZED_WAIT_FACTOR=0.5

EXTERNAL_VOID_RETRY_MAX_ATTEMPTS=3
EXTERNAL_VOID_RETRY_WAIT_DURATION=300ms
EXTERNAL_VOID_RETRY_ENABLE_EXPONENTIAL_BACKOFF=true
EXTERNAL_VOID_RETRY_EXPONENTIAL_BACKOFF_MULTIPLIER=2.0
EXTERNAL_VOID_RETRY_EXPONENTIAL_MAX_WAIT_DURATION=2s
EXTERNAL_VOID_RETRY_ENABLE_RANDOMIZED_WAIT=true
EXTERNAL_VOID_RETRY_RANDOMIZED_WAIT_FACTOR=0.5

EXTERNAL_AUTHORIZE_CB_SLIDING_WINDOW_SIZE=10
EXTERNAL_AUTHORIZE_CB_MINIMUM_CALLS=5
EXTERNAL_AUTHORIZE_CB_FAILURE_RATE_THRESHOLD=50
EXTERNAL_AUTHORIZE_CB_WAIT_DURATION_IN_OPEN_STATE=30s
EXTERNAL_AUTHORIZE_CB_PERMITTED_CALLS_IN_HALF_OPEN=3

EXTERNAL_CONFIRM_CB_SLIDING_WINDOW_SIZE=10
EXTERNAL_CONFIRM_CB_MINIMUM_CALLS=5
EXTERNAL_CONFIRM_CB_FAILURE_RATE_THRESHOLD=50
EXTERNAL_CONFIRM_CB_WAIT_DURATION_IN_OPEN_STATE=30s
EXTERNAL_CONFIRM_CB_PERMITTED_CALLS_IN_HALF_OPEN=3

EXTERNAL_VOID_CB_SLIDING_WINDOW_SIZE=10
EXTERNAL_VOID_CB_MINIMUM_CALLS=5
EXTERNAL_VOID_CB_FAILURE_RATE_THRESHOLD=50
EXTERNAL_VOID_CB_WAIT_DURATION_IN_OPEN_STATE=30s
EXTERNAL_VOID_CB_PERMITTED_CALLS_IN_HALF_OPEN=3

EXTERNAL_AUTHORIZE_BULKHEAD_MAX_CONCURRENT_CALLS=10
EXTERNAL_AUTHORIZE_BULKHEAD_MAX_WAIT_DURATION=0ms

EXTERNAL_CONFIRM_BULKHEAD_MAX_CONCURRENT_CALLS=10
EXTERNAL_CONFIRM_BULKHEAD_MAX_WAIT_DURATION=0ms

EXTERNAL_VOID_BULKHEAD_MAX_CONCURRENT_CALLS=10
EXTERNAL_VOID_BULKHEAD_MAX_WAIT_DURATION=0ms
